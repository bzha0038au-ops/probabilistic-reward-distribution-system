# Backup runner configuration for local cron or ad hoc execution.

BACKUP_ROOT=/var/lib/reward-system/ops/backups
OFFSITE_STORAGE_URI=ssh://backup@example.net/var/backups/reward-system
BACKUP_ENCRYPTION_PASSPHRASE=replace-with-a-long-random-passphrase
LOCAL_RETENTION_DAYS=35
OFFSITE_RETENTION_DAYS=90
INCLUDE_VOLUME_BACKUP=true

# Optional overrides.
# DATABASE_VOLUME_NAME=reward-system_reward_postgres_data
# KEEP_LOCAL_PLAINTEXT=false
# S3_BACKUP_URI=s3://reward-backup-primary/logical
# S3_CROSS_REGION_URI=s3://reward-backup-dr/logical
# S3_BACKUP_SSE=AES256
# S3_BACKUP_STORAGE_CLASS=STANDARD_IA
# S3_BACKUP_KMS_KEY_ID=arn:aws:kms:ap-southeast-2:123456789012:key/replace-me

# Repo-level ops command defaults (`pnpm ops:*`).
# When running on a deployed host, these usually point at $DEPLOY_PATH/current.

DEPLOY_ENVIRONMENT=production

# Health / metrics probes.
OPS_HEALTH_URLS=http://127.0.0.1:4000/health/ready
OPS_METRICS_URLS=http://127.0.0.1:4000/metrics

# `docker compose logs` collection for AI diagnosis / postmortem helpers.
OPS_LOG_SERVICES=backend,notification-worker,reverse-proxy
OPS_LOG_TAIL=200
OPS_POSTMORTEM_LOG_TAIL=500
OPS_POSTMORTEM_SINCE=4h

# Sentry 5xx lookup for `pnpm ops:tail-errors`.
SENTRY_ORG=
SENTRY_PROJECTS=
OPS_SENTRY_ENVIRONMENT=production
# Prefer loading this from a secret manager or shell export, not plaintext env files.
# SENTRY_AUTH_TOKEN=

# AI-backed diagnosis / postmortem drafting.
# Prefer loading this from a secret manager or shell export, not plaintext env files.
# OPENAI_API_KEY=
OPS_AI_MODEL=
