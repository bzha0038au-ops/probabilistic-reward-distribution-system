COMPOSE_PROJECT_NAME=reward-system
PUBLIC_HTTP_PORT=80
PUBLIC_HTTPS_PORT=443

APP_DOMAIN=app.example.com
ADMIN_DOMAIN=admin.example.com
API_DOMAIN=api.example.com
TLS_ACME_EMAIL=ops@example.com
# Start with one day to validate HSTS safely, then raise toward 31536000.
HSTS_MAX_AGE=86400

POSTGRES_IMAGE=postgres:16
REDIS_IMAGE=redis:7
PROXY_IMAGE=caddy:2.8
BACKEND_IMAGE=reward-system/backend
FRONTEND_IMAGE=reward-system/frontend
ADMIN_IMAGE=reward-system/admin
