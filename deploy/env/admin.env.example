NODE_ENV=production
HOST=0.0.0.0
PORT=3000
ORIGIN=https://admin.example.com

ADMIN_BASE_URL=https://admin.example.com
API_BASE_URL=http://backend:4000
PUBLIC_API_BASE_URL=https://api.example.com
SENTRY_DSN=
PUBLIC_SENTRY_DSN=
PUBLIC_OBSERVABILITY_ENVIRONMENT=production
PUBLIC_OBSERVABILITY_RELEASE=2026.04.27
PUBLIC_OBSERVABILITY_COMMIT_SHA=replace-with-commit-sha

ADMIN_JWT_SECRET_FILE=/run/secrets/admin_jwt_secret
# Optional smooth-rotation fallback file for admin session verification.
# ADMIN_JWT_SECRET_PREVIOUS_FILE=/run/secrets/admin_jwt_secret_previous
ADMIN_SESSION_TTL=7200
