NODE_ENV=production
PORT=4000

# Secret manager should materialize these files into the host's secrets
# directory, which compose mounts read-only at /run/secrets.
DATABASE_URL_FILE=/run/secrets/backend_database_url
POSTGRES_URL_FILE=/run/secrets/backend_database_url
POSTGRES_SSL=false
REDIS_URL_FILE=/run/secrets/backend_redis_url

WEB_BASE_URL=https://app.example.com
ADMIN_BASE_URL=https://admin.example.com
# Keep finance flows on manual review by default. Automated mode requires both
# PAYMENT_OPERATING_MODE=automated and PAYMENT_AUTOMATED_MODE_OPT_IN=true after
# an explicit rollout decision.
PAYMENT_OPERATING_MODE=manual_review
PAYMENT_AUTOMATED_MODE_OPT_IN=false
PAYMENT_OUTBOUND_WORKER_INTERVAL_MS=1000
PAYMENT_OUTBOUND_BATCH_SIZE=25
PAYMENT_OUTBOUND_LOCK_TIMEOUT_MS=120000
PAYMENT_OUTBOUND_UNKNOWN_RETRY_DELAY_MS=30000
# Optional logical-ref secret root for payment provider config.secretRefs.*.
# Example secretRefs.apiKey = sm/payment/stripe/api-key maps to:
# /run/secrets/payment-providers/sm/payment/stripe/api-key
# PAYMENT_PROVIDER_SECRET_REF_DIR=/run/secrets/payment-providers

ADMIN_JWT_SECRET_FILE=/run/secrets/admin_jwt_secret
USER_JWT_SECRET_FILE=/run/secrets/user_jwt_secret
# Optional smooth-rotation fallback files. Keep them set only for the drain window.
# ADMIN_JWT_SECRET_PREVIOUS_FILE=/run/secrets/admin_jwt_secret_previous
# USER_JWT_SECRET_PREVIOUS_FILE=/run/secrets/user_jwt_secret_previous
ADMIN_MFA_ENCRYPTION_SECRET_FILE=/run/secrets/admin_mfa_encryption_secret
ADMIN_MFA_BREAK_GLASS_SECRET_FILE=/run/secrets/admin_mfa_break_glass_secret

LOG_LEVEL=info
DRAW_POOL_CACHE_TTL_SECONDS=30
OBSERVABILITY_SERVICE_NAME=reward-backend
OBSERVABILITY_ENVIRONMENT=production
OBSERVABILITY_RELEASE=2026.04.27
OBSERVABILITY_COMMIT_SHA=replace-with-commit-sha
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_TRACE_SAMPLE_RATIO=0.2
SECURITY_EVENT_SINKS=log
# Optional direct security-event sinks. `log` is sufficient when Datadog Logs,
# Vector, or another collector already tails container stdout.
SECURITY_EVENT_WEBHOOK_URL=
SECURITY_EVENT_REQUEST_TIMEOUT_MS=5000
SECURITY_EVENT_ELASTICSEARCH_URL=
# SECURITY_EVENT_ELASTICSEARCH_API_KEY_FILE=/run/secrets/security_event_elasticsearch_api_key
SECURITY_EVENT_ELASTICSEARCH_INDEX=reward-security-events
OBSERVABILITY_WITHDRAW_STUCK_THRESHOLD_MINUTES=60
KYC_REVERIFICATION_WORKER_ENABLED=true
KYC_REVERIFICATION_WORKER_INTERVAL_MS=3600000
KYC_REVERIFICATION_NOTICE_DAYS=30

AUTH_SMTP_HOST=
AUTH_SMTP_PORT=587
AUTH_SMTP_SECURE=false
AUTH_SMTP_USER=
# AUTH_SMTP_PASS_FILE=/run/secrets/auth_smtp_pass
AUTH_EMAIL_FROM=

AUTH_TWILIO_ACCOUNT_SID=
# AUTH_TWILIO_AUTH_TOKEN_FILE=/run/secrets/auth_twilio_auth_token
AUTH_TWILIO_FROM_NUMBER=
AUTH_TWILIO_MESSAGING_SERVICE_SID=
