NODE_ENV=production
PORT=3000

AUTH_SECRET_FILE=/run/secrets/frontend_auth_secret
USER_JWT_SECRET_FILE=/run/secrets/user_jwt_secret
# Optional smooth-rotation fallback file for backend user-session verification.
# USER_JWT_SECRET_PREVIOUS_FILE=/run/secrets/user_jwt_secret_previous
AUTH_TRUST_HOST=true
SENTRY_DSN=

API_BASE_URL=http://backend:4000
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_OBSERVABILITY_ENVIRONMENT=production
NEXT_PUBLIC_OBSERVABILITY_RELEASE=2026.04.27
NEXT_PUBLIC_OBSERVABILITY_COMMIT_SHA=replace-with-commit-sha
