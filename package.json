{
  "name": "reward-system",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel --filter ./apps/frontend --filter ./apps/admin --filter ./apps/backend dev",
    "dev:user": "pnpm -r --parallel --filter ./apps/frontend --filter ./apps/mobile --filter ./apps/backend dev",
    "dev:frontend": "pnpm --dir apps/frontend dev",
    "dev:saas-portal": "pnpm --dir apps/saas-portal dev",
    "dev:mobile": "pnpm --dir apps/mobile dev",
    "dev:admin": "pnpm --dir apps/admin dev",
    "dev:backend": "pnpm --dir apps/backend dev",
    "dev:fairness-audits": "pnpm --dir apps/backend dev:worker:fairness-audits",
    "dev:holdem-timeouts": "pnpm --dir apps/backend dev:worker:holdem-timeouts",
    "dev:blackjack-timeouts": "pnpm --dir apps/backend dev:worker:blackjack-timeouts",
    "dev:notifications": "pnpm --dir apps/backend dev:worker:notifications",
    "dev:reconciliation": "pnpm --dir apps/backend dev:worker:reconciliation",
    "dev:wallet-reconciliation": "pnpm --dir apps/backend dev:worker:wallet-reconciliation",
    "dev:payment-webhooks": "pnpm --dir apps/backend dev:worker:payment-webhooks",
    "dev:saas-billing": "pnpm --dir apps/backend dev:worker:saas-billing",
    "mobile:ios": "pnpm --dir apps/mobile ios",
    "mobile:android": "pnpm --dir apps/mobile android",
    "mobile:android:dev-client": "pnpm --dir apps/mobile android:dev-client",
    "mobile:android:regression": "pnpm --dir apps/mobile android:regression",
    "mobile:release:preview": "pnpm --dir apps/mobile release:preview",
    "mobile:release:production": "pnpm --dir apps/mobile release:production",
    "mobile:release:ios": "pnpm --dir apps/mobile release:ios",
    "mobile:release:android": "pnpm --dir apps/mobile release:android",
    "mobile:submit:android:internal": "pnpm --dir apps/mobile submit:android:internal",
    "mobile:submit:android:production": "pnpm --dir apps/mobile submit:android:production",
    "mobile:submit:ios": "pnpm --dir apps/mobile submit:ios",
    "guard:generated-src-js": "node scripts/check-generated-src-js.mjs",
    "build": "pnpm -r --filter ./apps/frontend --filter ./apps/saas-portal --filter ./apps/admin --filter ./apps/backend --filter ./apps/database --filter ./apps/shared-types --filter ./packages/user-core --filter ./packages/prize-engine-sdk build",
    "check": "pnpm guard:generated-src-js && pnpm -r --filter ./apps/frontend --filter ./apps/saas-portal --filter ./apps/mobile --filter ./apps/admin --filter ./apps/backend --filter ./apps/database --filter ./apps/shared-types --filter ./packages/user-core --filter ./packages/prize-engine-sdk check",
    "lint": "pnpm -r --filter ./apps/frontend --filter ./apps/saas-portal --filter ./apps/mobile --filter ./apps/admin --filter ./apps/backend --filter ./apps/database --filter ./apps/shared-types --filter ./packages/user-core --filter ./packages/prize-engine-sdk lint",
    "test": "pnpm -r --if-present test",
    "db:generate": "pnpm --dir apps/database db:generate",
    "db:migrate": "pnpm --dir apps/database db:migrate",
    "db:studio": "pnpm --dir apps/database db:studio",
    "db:seed:manual": "pnpm --dir apps/backend seed:manual",
    "db:seed:saas-portal-demo": "pnpm --dir apps/backend seed:saas-portal-demo",
    "verify:saas-decision-billing": "pnpm --dir apps/backend verify:decision-class-billing",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d postgres redis",
    "ops:health": "tsx scripts/ops/health.ts",
    "ops:tail-errors": "tsx scripts/ops/tail-errors.ts",
    "ops:check-finance": "tsx scripts/ops/check-finance.ts",
    "ops:freeze-deploys": "tsx scripts/ops/freeze-deploys.ts",
    "ops:rotate-jwt": "tsx scripts/ops/rotate-jwt.ts",
    "ops:ai-diagnose": "tsx scripts/ops/ai-diagnose.ts",
    "ops:postmortem": "tsx scripts/ops/postmortem.ts",
    "test:integration": "env -u NO_COLOR tsx tests/integration/run.ts",
    "test:integration:critical": "env -u NO_COLOR tsx tests/integration/run.ts --critical",
    "test:e2e": "env -u NO_COLOR tsx tests/e2e/run.ts",
    "test:e2e:critical": "env -u NO_COLOR tsx tests/e2e/run.ts --critical",
    "test:e2e:install": "playwright install chromium",
    "test:load": "tsx tests/load/wallet-smoke.ts",
    "test:load:mutations": "tsx tests/load/mutation-smoke.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "autocannon": "^8.0.0",
    "pg-embedded": "^0.2.3",
    "postgres": "^3.4.9",
    "tsx": "^4.21.0"
  }
}
