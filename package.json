{
  "name": "reward-system",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel --filter ./apps/frontend --filter ./apps/admin --filter ./apps/backend dev",
    "dev:frontend": "pnpm --dir apps/frontend dev",
    "dev:admin": "pnpm --dir apps/admin dev",
    "dev:backend": "pnpm --dir apps/backend dev",
    "build": "pnpm -r --filter ./apps/frontend --filter ./apps/admin --filter ./apps/backend --filter ./apps/database --filter ./apps/shared-types build",
    "check": "pnpm -r --filter ./apps/frontend --filter ./apps/admin --filter ./apps/backend --filter ./apps/database --filter ./apps/shared-types check",
    "lint": "pnpm -r --filter ./apps/frontend --filter ./apps/admin --filter ./apps/backend --filter ./apps/database --filter ./apps/shared-types lint",
    "test": "pnpm -r --if-present test",
    "db:generate": "pnpm --dir apps/database db:generate",
    "db:migrate": "pnpm --dir apps/database db:migrate",
    "db:studio": "pnpm --dir apps/database db:studio",
    "db:seed:manual": "pnpm --dir apps/backend seed:manual",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d postgres redis",
    "test:integration": "RUN_INTEGRATION_TESTS=true DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/reward_local POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:5433/reward_local pnpm --dir apps/backend test"
  }
}
