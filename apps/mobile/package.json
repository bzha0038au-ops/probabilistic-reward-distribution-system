{
  "name": "@reward/mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "test": "pnpm test:node && pnpm test:vitest",
    "test:node": "pnpm exec tsx --test test/**/*.test.ts",
    "test:vitest": "sh ../../scripts/run-vitest.sh run --config vitest.config.ts",
    "android": "expo run:android",
    "android:dev-client": "expo start --dev-client --port 8081 --clear",
    "android:regression": "node ./scripts/android-dev-regression.mjs",
    "e2e:prepare": "pnpm exec tsx ./scripts/prepare-maestro-e2e.ts",
    "e2e:maestro:holdem": "maestro test -e REWARD_MOBILE_APP_ID=${REWARD_MOBILE_APP_ID:-com.anonymous.rewardmobile} ./e2e/maestro/holdem.yaml",
    "e2e:maestro:prediction-market": "maestro test -e REWARD_MOBILE_APP_ID=${REWARD_MOBILE_APP_ID:-com.anonymous.rewardmobile} ./e2e/maestro/prediction-market.yaml",
    "e2e:maestro:notifications": "maestro test -e REWARD_MOBILE_APP_ID=${REWARD_MOBILE_APP_ID:-com.anonymous.rewardmobile} ./e2e/maestro/notifications.yaml",
    "e2e:maestro:all": "node ./scripts/run-maestro-suite.mjs",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "release:preview": "eas build --profile preview",
    "release:production": "eas build --profile production",
    "release:ios": "eas build --platform ios --profile production",
    "release:android": "eas build --platform android --profile production",
    "submit:android:internal": "eas submit --platform android --profile internal",
    "submit:android:production": "eas submit --platform android --profile production",
    "submit:ios": "eas submit --platform ios --profile production",
    "check": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.12",
    "@reward/shared-types": "workspace:*",
    "@reward/user-core": "workspace:*",
    "expo": "~55.0.18",
    "expo-build-properties": "~55.0.13",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.15",
    "expo-device": "~55.0.15",
    "expo-iap": "^4.2.3",
    "expo-notifications": "~55.0.21",
    "expo-secure-store": "~55.0.13",
    "expo-status-bar": "~55.0.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.16.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20.10.5",
    "@types/react": "~19.2.14",
    "dotenv": "^17.3.1",
    "eas-cli": "^18.8.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
