{
  "name": "@reward/mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "release:preview": "eas build --profile preview",
    "release:production": "eas build --profile production",
    "release:ios": "eas build --platform ios --profile production",
    "release:android": "eas build --platform android --profile production",
    "submit:android:internal": "eas submit --platform android --profile internal",
    "submit:android:production": "eas submit --platform android --profile production",
    "submit:ios": "eas submit --platform ios --profile production",
    "check": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@reward/shared-types": "workspace:*",
    "@reward/user-core": "workspace:*",
    "expo": "~54.0.33",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/react": "~19.1.0",
    "eas-cli": "^18.8.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
