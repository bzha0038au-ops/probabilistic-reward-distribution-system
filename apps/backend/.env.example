# Postgres connection string
DATABASE_URL=
POSTGRES_URL=
POSTGRES_SSL=false

# Admin and user JWT secrets (must not be shared, 32+ chars in prod)
ADMIN_JWT_SECRET=
USER_JWT_SECRET=
# Dedicated key for encrypting admin MFA secrets in storage.
# Local development may fall back to ADMIN_JWT_SECRET, but production must set this separately.
ADMIN_MFA_ENCRYPTION_SECRET=
# Emergency break-glass secret for audited admin MFA recovery.
# Optional in local development, required in production, and must not match other secrets.
ADMIN_MFA_BREAK_GLASS_SECRET=
# ADMIN_SESSION_TTL=7200
# USER_SESSION_TTL=28800

# Backend server
PORT=4000
WEB_BASE_URL=http://localhost:3000
ADMIN_BASE_URL=http://localhost:5173
OBSERVABILITY_SERVICE_NAME=reward-backend
OBSERVABILITY_ENVIRONMENT=development
OBSERVABILITY_RELEASE=local
OBSERVABILITY_COMMIT_SHA=local
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
# Point this at your OTLP/HTTP collector base URL; the backend appends /v1/traces.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_TRACE_SAMPLE_RATIO=1
OBSERVABILITY_WITHDRAW_STUCK_THRESHOLD_MINUTES=60
# Keep finance flows on manual review until the backend owns outbound gateway
# execution, signed payment callbacks, retries, and recovery.
# `automated` is intentionally unsupported today and will fail startup.
PAYMENT_OPERATING_MODE=manual_review
PAYMENT_RECONCILIATION_ENABLED=true
PAYMENT_RECONCILIATION_INTERVAL_MS=300000
PAYMENT_RECONCILIATION_LOOKBACK_MINUTES=1440
PAYMENT_RECONCILIATION_PENDING_TIMEOUT_MINUTES=15
PAYMENT_RECONCILIATION_MAX_ORDERS_PER_PROVIDER=200
PAYMENT_OPERATIONS_ENABLED=true
PAYMENT_OPERATIONS_INTERVAL_MS=300000
PAYMENT_OPERATIONS_TIMEOUT_MINUTES=60
PAYMENT_OPERATIONS_BATCH_SIZE=100
PAYMENT_WEBHOOK_WORKER_INTERVAL_MS=1000
PAYMENT_WEBHOOK_BATCH_SIZE=25
PAYMENT_WEBHOOK_LOCK_TIMEOUT_MS=120000
PAYMENT_OUTBOUND_WORKER_INTERVAL_MS=1000
PAYMENT_OUTBOUND_BATCH_SIZE=25
PAYMENT_OUTBOUND_LOCK_TIMEOUT_MS=120000
PAYMENT_OUTBOUND_UNKNOWN_RETRY_DELAY_MS=30000
# Optional per-provider signing secret env. Example for provider name "stripe":
# PAYMENT_WEBHOOK_SECRET__STRIPE=

# Auth delivery + token windows
AUTH_NOTIFICATION_WEBHOOK_URL=
AUTH_NOTIFICATION_REQUEST_TIMEOUT_MS=10000
AUTH_NOTIFICATION_WORKER_INTERVAL_MS=1000
AUTH_NOTIFICATION_BATCH_SIZE=25
AUTH_NOTIFICATION_RETRY_BASE_MS=5000
AUTH_NOTIFICATION_RETRY_MAX_MS=300000
AUTH_NOTIFICATION_MAX_ATTEMPTS=6
AUTH_NOTIFICATION_LOCK_TIMEOUT_MS=120000
AUTH_NOTIFICATION_EMAIL_THROTTLE_MAX=3
AUTH_NOTIFICATION_EMAIL_THROTTLE_WINDOW_MS=900000
AUTH_NOTIFICATION_SMS_THROTTLE_MAX=3
AUTH_NOTIFICATION_SMS_THROTTLE_WINDOW_MS=600000
AUTH_NOTIFICATION_ALERT_THROTTLE_MAX=2
AUTH_NOTIFICATION_ALERT_THROTTLE_WINDOW_MS=3600000
AUTH_SMTP_HOST=
AUTH_SMTP_PORT=587
AUTH_SMTP_SECURE=false
AUTH_SMTP_USER=
AUTH_SMTP_PASS=
AUTH_EMAIL_FROM=
AUTH_TWILIO_ACCOUNT_SID=
AUTH_TWILIO_AUTH_TOKEN=
AUTH_TWILIO_FROM_NUMBER=
AUTH_TWILIO_MESSAGING_SERVICE_SID=
PASSWORD_RESET_TTL_MINUTES=30
EMAIL_VERIFICATION_TTL_MINUTES=1440
PHONE_VERIFICATION_TTL_MINUTES=10
ANOMALOUS_LOGIN_LOOKBACK_DAYS=30

# Seed value for system_config.draw_cost (used on first read)
DRAW_COST=10

# Probability pool cache TTL (seconds, 0 disables)
DRAW_POOL_CACHE_TTL_SECONDS=30

# Optional Redis (rate limit + cache)
REDIS_URL=
