# Postgres connection string
DATABASE_URL=
POSTGRES_URL=
POSTGRES_SSL=false

# Admin and user JWT secrets (must not be shared, 32+ chars in prod)
ADMIN_JWT_SECRET=
USER_JWT_SECRET=
# Optional dedicated key for encrypting admin MFA secrets in storage.
# Falls back to ADMIN_JWT_SECRET when unset, but production should set this separately.
ADMIN_MFA_ENCRYPTION_SECRET=
# ADMIN_SESSION_TTL=7200
# USER_SESSION_TTL=28800

# Backend server
PORT=4000
WEB_BASE_URL=http://localhost:3000
ADMIN_BASE_URL=http://localhost:5173

# Auth delivery + token windows
AUTH_NOTIFICATION_WEBHOOK_URL=
PASSWORD_RESET_TTL_MINUTES=30
EMAIL_VERIFICATION_TTL_MINUTES=1440
PHONE_VERIFICATION_TTL_MINUTES=10
ANOMALOUS_LOGIN_LOOKBACK_DAYS=30

# Seed value for system_config.draw_cost (used on first read)
DRAW_COST=10

# Probability pool cache TTL (seconds, 0 disables)
DRAW_POOL_CACHE_TTL_SECONDS=30

# Optional Redis (rate limit + cache)
REDIS_URL=
