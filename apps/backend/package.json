    "dev:worker:db-partition-maintenance": "tsx watch src/workers/db-partition-maintenance-worker.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node --import tsx dist/server.js",
    "start:worker:fairness-audits": "node --import tsx dist/workers/fairness-audit-worker.js",
    "start:worker:kyc-reverification": "node --import tsx dist/workers/kyc-reverification-worker.js",
    "start:worker:holdem-timeouts": "node --import tsx dist/workers/holdem-timeout-worker.js",
    "start:worker:blackjack-timeouts": "node --import tsx dist/workers/blackjack-timeout-worker.js",
    "start:worker:notifications": "node --import tsx dist/workers/auth-notification-worker.js",
    "start:worker:payment-outbound": "node --import tsx dist/workers/payment-outbound-worker.js",
    "start:worker:payment-operations": "node --import tsx dist/workers/payment-operations-worker.js",
    "start:worker:reconciliation": "node --import tsx dist/workers/payment-reconciliation-worker.js",
    "start:worker:wallet-reconciliation": "node --import tsx dist/workers/wallet-reconciliation-worker.js",
    "start:worker:payment-webhooks": "node --import tsx dist/workers/payment-webhook-worker.js",
    "start:worker:prediction-market-oracles": "node --import tsx dist/workers/prediction-market-oracle-worker.js",
    "start:worker:saas-billing": "node --import tsx dist/workers/saas-billing-worker.js",
    "start:worker:db-partition-maintenance": "node --import tsx dist/workers/db-partition-maintenance-worker.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0 && tsx scripts/check-prize-engine-tenant-scope.ts",
    "lint:prize-engine-scope": "tsx scripts/check-prize-engine-tenant-scope.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/websocket": "^11.2.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/instrumentation": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@reward/database": "workspace:*",
    "@reward/shared-types": "workspace:*",
    "@sentry/node": "^10.51.0",
    "ajv": "^8.20.0",
    "bcrypt-ts": "^5.0.0",
    "convict": "^6.2.5",
    "decimal.js": "^10.4.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "geoip-lite": "^2.0.1",
    "ioredis": "^5.10.1",
    "jose": "^5.5.1",
    "nodemailer": "^8.0.7",
    "pino": "^9.4.0",
    "postgres": "^3.4.9",
    "prom-client": "^15.1.3",
    "stripe": "^22.1.0",
    "tsx": "^4.19.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/convict": "^6.1.3",
    "@types/nodemailer": "^8.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.2",
    "light-my-request": "^5.14.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.5",
    "ws": "^8.19.0"
  }
}
