{
  "name": "@reward/backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "admin:promote": "node scripts/promote-admin.js",
    "user:reset-password": "node scripts/reset-password.js",
    "seed:manual": "tsx scripts/seed-manual.ts",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json --outDir dist",
    "check": "tsc -p tsconfig.json --noEmit",
