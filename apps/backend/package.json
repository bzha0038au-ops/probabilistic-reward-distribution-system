{
  "name": "@reward/backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "files": [
    "dist",
    "scripts",
    "src",
    "package.json",
    "tsconfig.build.json",
    "tsconfig.json",
    ".env.example",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "admin:promote": "node scripts/promote-admin.js",
    "user:reset-password": "node scripts/reset-password.js",
    "seed:manual": "tsx scripts/seed-manual.ts",
    "dev": "tsx watch src/server.ts",
    "dev:worker:notifications": "tsx watch src/workers/auth-notification-worker.ts",
    "dev:worker:payment-outbound": "tsx watch src/workers/payment-outbound-worker.ts",
    "dev:worker:payment-operations": "tsx watch src/workers/payment-operations-worker.ts",
    "dev:worker:reconciliation": "tsx watch src/workers/payment-reconciliation-worker.ts",
    "dev:worker:payment-webhooks": "tsx watch src/workers/payment-webhook-worker.ts",
    "dev:worker:saas-billing": "tsx watch src/workers/saas-billing-worker.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node --import tsx dist/server.js",
    "start:worker:notifications": "node --import tsx dist/workers/auth-notification-worker.js",
    "start:worker:payment-outbound": "node --import tsx dist/workers/payment-outbound-worker.js",
    "start:worker:payment-operations": "node --import tsx dist/workers/payment-operations-worker.js",
    "start:worker:reconciliation": "node --import tsx dist/workers/payment-reconciliation-worker.js",
    "start:worker:payment-webhooks": "node --import tsx dist/workers/payment-webhook-worker.js",
    "start:worker:saas-billing": "node --import tsx dist/workers/saas-billing-worker.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0 && tsx scripts/check-prize-engine-tenant-scope.ts",
    "lint:prize-engine-scope": "tsx scripts/check-prize-engine-tenant-scope.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/rate-limit": "^9.1.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/instrumentation": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@reward/database": "workspace:*",
    "@reward/shared-types": "workspace:*",
    "@sentry/node": "^10.50.0",
    "ajv": "^8.17.1",
    "bcrypt-ts": "^5.0.0",
    "convict": "^6.2.4",
    "decimal.js": "^10.4.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.29.2",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.5.0",
    "jose": "^5.5.1",
    "nodemailer": "^6.10.1",
    "pino": "^9.4.0",
    "postgres": "^3.4.3",
    "prom-client": "^15.1.3",
    "stripe": "^22.1.0",
    "tsx": "^4.19.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/convict": "^6.1.3",
    "@types/nodemailer": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.2",
    "light-my-request": "^5.14.0",
    "typescript": "^5.3.3",
    "vitest": "^3.0.7"
  }
}
