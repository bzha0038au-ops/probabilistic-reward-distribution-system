{
  "name": "@reward/backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "files": [
    "dist",
    "scripts",
    "src",
    "package.json",
    "tsconfig.build.json",
    "tsconfig.json",
    ".env.example",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "admin:promote": "node scripts/promote-admin.js",
    "user:reset-password": "node scripts/reset-password.js",
    "seed:manual": "tsx scripts/seed-manual.ts",
    "seed:saas-portal-demo": "tsx scripts/seed-saas-portal-demo.ts",
    "verify:decision-class-billing": "tsx scripts/verify-decision-class-billing.ts",
    "dev": "tsx watch src/server.ts",
    "dev:worker:fairness-audits": "tsx watch src/workers/fairness-audit-worker.ts",
    "dev:worker:kyc-reverification": "tsx watch src/workers/kyc-reverification-worker.ts",
    "dev:worker:holdem-timeouts": "tsx watch src/workers/holdem-timeout-worker.ts",
    "dev:worker:blackjack-timeouts": "tsx watch src/workers/blackjack-timeout-worker.ts",
    "dev:worker:notifications": "tsx watch src/workers/auth-notification-worker.ts",
    "dev:worker:payment-outbound": "tsx watch src/workers/payment-outbound-worker.ts",
    "dev:worker:payment-operations": "tsx watch src/workers/payment-operations-worker.ts",
    "dev:worker:reconciliation": "tsx watch src/workers/payment-reconciliation-worker.ts",
    "dev:worker:wallet-reconciliation": "tsx watch src/workers/wallet-reconciliation-worker.ts",
    "dev:worker:payment-webhooks": "tsx watch src/workers/payment-webhook-worker.ts",
    "dev:worker:prediction-market-oracles": "tsx watch src/workers/prediction-market-oracle-worker.ts",
