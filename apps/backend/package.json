    "ajv": "^8.17.1",
    "bcrypt-ts": "^5.0.0",
    "convict": "^6.2.4",
    "decimal.js": "^10.4.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.29.2",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.5.0",
    "jose": "^5.5.1",
    "pino": "^9.4.0",
    "postgres": "^3.4.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/convict": "^6.1.3",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.3.3",
    "vitest": "^3.0.7"
  }
