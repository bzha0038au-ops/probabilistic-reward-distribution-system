    "@docusaurus/types": "^3.10.1",
    "@mdx-js/react": "^3.1.1",
    "@reward/shared-types": "workspace:*",
    "@scalar/docusaurus": "^0.8.12",
    "clsx": "^2.1.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
