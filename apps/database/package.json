{
  "name": "@reward/database",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "files": [
    "dist",
    "drizzle",
    "drizzle-baseline",
    "drizzle.config.ts",
    "scripts",
    "src",
    "package.json",
    "tsconfig.build.json",
    "tsconfig.json",
    ".env.example",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./orm": "./src/orm.ts",
    "./migration-runner": "./src/migration-runner.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@reward/shared-types": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "typescript": "^5.3.3"
  }
}
