{
  "name": "@reward/saas-status",
  "private": true,
  "scripts": {
    "dev": "rm -rf .next-dev && next dev --hostname localhost --port 3003",
    "dev:turbo": "rm -rf .next-dev && next dev --turbo --hostname localhost --port 3003",
    "build": "rm -rf .next-dev && next build",
    "start": "next start -H 0.0.0.0 -p 3003",
    "test": "tsx --test test/**/*.test.ts",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx --no-error-on-unmatched-pattern app components lib pages src",
    "check": "eslint --ext .js,.jsx,.ts,.tsx --no-error-on-unmatched-pattern app components lib pages src"
  },
  "dependencies": {
    "@reward/shared-types": "workspace:*",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "geist": "^1.2.0",
    "next": "^15.5.15",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "eslint": "8.56.0",
    "eslint-config-next": "^15.5.15",
    "postcss": "^8.5.13",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3"
  }
}
