# Auth.js / NextAuth (frontend-only secret)
AUTH_SECRET=
USER_JWT_SECRET=
# Optional backend user-session verification fallback during secret rotation.
USER_JWT_SECRET_PREVIOUS=
AUTH_TRUST_HOST=true
SENTRY_DSN=

# Backend API
API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_COMMUNITY_TURNSTILE_SITE_KEY=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_OBSERVABILITY_ENVIRONMENT=development
NEXT_PUBLIC_OBSERVABILITY_RELEASE=local
NEXT_PUBLIC_OBSERVABILITY_COMMIT_SHA=local
